# ── Database (self-hosted Supabase Postgres on Mumbai VPS, via Cloudflare Tunnel) ──
# postgres://USER:PASSWORD@TUNNEL_HOSTNAME:5432/postgres
DATABASE_URL=

# ── Supabase (self-hosted) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# ── Token vault (AES-256-GCM key, 32 bytes hex/base64 — generate with: openssl rand -hex 32) ──
# NEVER log, echo, or commit this. Rotating it invalidates all stored Discord tokens.
TOKEN_ENC_KEY=

# ── LLM providers (DeepSeek default generator, Claude Sonnet escalation — desandria.md §1) ──
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ── Payments ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ── Cloudflare R2 (artifacts + backups — desandria.md §5.7) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_ARTIFACTS=artifacts
R2_BUCKET_BACKUPS=backups

# ── Capacity & cost guardrails (desandria.md §1, §4.3) ──
MAX_HOSTED_BOTS=50
LLM_MONTHLY_CAP_USD=50
